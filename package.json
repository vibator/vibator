{
  "name": "vibator",
  "version": "0.0.1",
  "description": "AI-first quality gates: configurable, glob-scoped rules that tell an agent what is wrong, what was expected, and where the standard is written down.",
  "type": "module",
  "license": "MIT",
  "author": "Josep Boix Requesens",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vibator/vibator.git"
  },
  "bugs": {
    "url": "https://github.com/vibator/vibator/issues"
  },
  "homepage": "https://github.com/vibator/vibator#readme",
  "keywords": [
    "lint",
    "quality",
    "guardrails",
    "static-analysis",
    "ai",
    "codegen"
  ],
  "bin": {
    "vibator": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./schema.json": "./schema.json",
    "./docs/*": "./docs/*",
    "./skills/*": "./skills/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "docs",
    "skills",
    "schema.json",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "arch": "depcruise src --config .dependency-cruiser.cjs",
    "build": "tsc -p tsconfig.build.json && npm run generate",
    "format": "biome format --write",
    "knip": "knip",
    "lint": "biome check",
    "prepare": "husky",
    "vibator": "node dist/cli.js",
    "test": "vitest run --coverage",
    "verify": "npm run lint && npm run arch && npm run knip && npm run build && npm run test && npm run vibator",
    "generate": "node --experimental-strip-types src/schema.ts && node --experimental-strip-types src/catalog.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "typescript": ">=5.4"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^22.20.1",
    "@vitest/coverage-v8": "^4.1.10",
    "dependency-cruiser": "^18.1.0",
    "husky": "^9.1.7",
    "knip": "^6.29.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
